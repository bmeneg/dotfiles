{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "google": {
      "options": {
        "projectId": "brdeoliv-code-assistant"
      }
    }
  },
  "mcp": {
    "lkml": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/zampierilucas/lkml-mcp",
        "lkml-mcp"
      ],
      "enabled": true
    },
    "wtmcp": {
      "type": "local",
      "command": [
        "go",
        "run",
        "github.com/LeGambiArt/wtmcp/cmd/wtmcp@latest"
      ],
      "enabled": true
    }
  }
}
